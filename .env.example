# FireBoard Cloud API Credentials
# If left blank or default, the application runs in local Simulation Mode
FIREBOARD_USERNAME=your_username_here
FIREBOARD_PASSWORD=your_password_here

# Database Configuration
# Remote Turso URL (e.g. libsql://your-db-name.turso.io)
# For local offline testing, use: sqlite:///docs/research/local.db
DB_URL=sqlite:///docs/research/local.db
DB_AUTH_TOKEN=

# App Settings
ENVIRONMENT=development
JWT_SECRET=generate_a_secure_random_string_here
